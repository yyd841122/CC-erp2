# CC-ERP .gitignore

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local data
*.log

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build output
dist/
dist-ssr/
build/

# Cache
.cache/
.temp/

# OS generated files
Thumbs.db
Desktop.ini

# Package manager lock files (optional, uncomment if needed)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
